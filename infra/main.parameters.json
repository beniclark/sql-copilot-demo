{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION=eastus2}"
    },
    "presenterIp": {
      "value": "${PRESENTER_IP}"
    },
    "entraAdminLoginName": {
      "value": "${ENTRA_ADMIN_UPN}"
    },
    "sqlAdminLogin": {
      "value": "${SQL_ADMIN_LOGIN=demoadmin}"
    },
    "sqlAdminPassword": {
      "value": "${SQL_ADMIN_PASSWORD}"
    },
    "vmAdminUsername": {
      "value": "${VM_ADMIN_USERNAME=azureuser}"
    },
    "vmAdminPassword": {
      "value": "${VM_ADMIN_PASSWORD}"
    },
    "vmSize": {
      "value": "${VM_SIZE=Standard_D2s_v5}"
    }
  }
}
